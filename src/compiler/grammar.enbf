//! # grammar
//!
//! Provides ground truth for all language grammar
//!
//! ## Invariants
//!
//! - Forms a single source of truth for all language grammar 
//!
//! Author: Cole Francis
//!
//! Last Updated: 06/19/2026

IDENT = letter (letter | digit | "_")* ;

literal = 
      bool_literal
    | int_literal
    | real_literal 
    | complex_literal 
    | math_const ;

bool_literal = "true" | "false"
int_literal = digit+ ;
real_literal = digit+ ("." digit+)? ;
complex_literal = "i" ;
math_const = "e" | "pi" ;

type = 
      "Bool"
    | "Int"
    | "Real"
    | "Complex" 
    | mod_type
    | IDENT ;

mod_type = "Mod" "(" int_literal ")" ;

arg_list =
    (IDENT "=" )? expr ("," (IDENT "=")? expr)* ;

expr = 
    binary_expr
    | tuple_expr
    | match_expr
    | sample_expr ;

binary_expr = equality ;

equality =
    comparison (("==" | "!=") comparison)* ;

comparison = 
    additive (("<" | ">" | "<=" | ">=") additive)* ;

additive =
    multiplicative (("+" | "-") multiplicative)* ;

multiplicative =
    unary (("*" | "/") unary )* ;

unary =
      ("-" | "!" | "~") primary ;
    | primary ;

primary =
      literal
    | IDENT
    | tuple_expr
    | "(" expr ")" ;

tuple_expr =
    "(" expr "," expr ("," expr)* ")" ;

match_expr =
    "match" expr "{"
        match_arm ("," match_arm)* ","?
    "}" ;

match_arm =
    pattern "=>" expr ;

pattern =
    simple_pattern ("|" simple_pattern)* ;

simple_pattern =
      "_"
    | literal
    | IDENT
    | tuple_pattern 
    | comparison_pattern ;

tuple_pattern =
    "(" simple_pattern ("," simple_pattern)+ ")" ;

comparison_pattern =
    ("<" | ">" | "<=" | ">=") expr ;

sample_expr = 
    "sample" "{"
        sample_arm ("," sample_arm)* ","?
    "}" ;

sample_arm =
    expr "=>" expr;

////////////////////////////////////////////////////////////////////////////////

program = (ent_decl | rel_decl | net_decl)* ;

////////////////////////////////////////////////////////////////////////////////

ent_decl =
    "ent" IDENT "=" ent_expr ";" ;

ent_expr = 
      type
    | set_ent ;

set_ent = "{" IDENT ("," IDENT)* "}" ;


////////////////////////////////////////////////////////////////////////////////

rel_decl =
    "rel" IDENT ":" "(" param_list? ")" "->" type "=" (expr | block_expr) ;

param_list =
    param ("," param)* ;

param =
    IDENT ":" type ;

block_expr = 
    "{"
        let_stmt*
        expr
    "}" ;

let_stmt = "let" IDENT "=" expr ";" ;

////////////////////////////////////////////////////////////////////////////////

net_decl = 
    "net" IDENT "{"
        module_item*
    "}" ;

module_item = 
      input_decl
    | output_decl
    | init_decl
    | assignment ;

input_decl =
    "input" IDENT ":" type ";" ;

output_decl =
    "output" IDENT ":" type ";" ;

init_decl = 
    "init" IDENT ":" type "=" expr ";" ;

assignment = 
    path "=" (inst | path) ";" ;

path =
      tuple_path
    | simple_path ;

tuple_path =
    "(" simple_path ("," simple_path)+ ")" ;

simple_path = 
    IDENT ("." IDENT)* ;

inst = 
    IDENT "(" arg_list? ")" ;

/////////////////////////////////////////////////